import whisper
import gradio as gr
model = whisper.load_model("base")
def speech_to_text(audio):
    result = model.transcribe(audio)
    return result["text"]
demo = gr.Interface(
    fn=speech_to_text,
    inputs=gr.Audio(type="filepath"),
    outputs=gr.Textbox(),
    title="Speech to Text"
)

demo.launch()
