import time, gradio as gr
from google import genai
from gtts import gTTS
client=genai.Client(api_key="AQ.Ab8RN6KYnzvSc1yoJClkb4MURbpwx5tBzXBmBX117sqKAXkepA")
def analyze_video(video_path):
  video = client.files.upload(file=video_path)
  while video.state.name=="PROCESSING":
    time.sleep(2)
    video=client.files.get(name=video.name)
  if video.state.name != "ACTIVE":
    return video_path, "Processing failed.", None
  response=client.models.generate_content(
      model="gemini-2.5-flash",
      contents=[video,"Describe everything happing in this video in detail."]
  )
  gTTS(text=response.text, lang="en").save("analysis.mp3")
  return video_path, response.text, "analysis.mp3"
gr.Interface(
  fn=analyze_video,
  inputs=gr.Video(label="Upload Video"),
  outputs=[gr.Video(), gr.Textbox(label="Analysis"), gr.Audio()],
  title="Video Analysis with Gemini"
).launch()
